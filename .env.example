FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-character-value

POSTGRES_DB=fireflight2
POSTGRES_USER=fireflight2
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql://fireflight2:change-me@fireflight2-db:5432/fireflight2

TIMEZONE=Europe/Berlin
SESSION_COOKIE_SECURE=true

FIREFLIGHT_ADMIN_USERNAME=admin
FIREFLIGHT_ADMIN_EMAIL=admin@example.org
FIREFLIGHT_ADMIN_PASSWORD=change-me

# DJI FlightHub 2: Zugangsdaten werden normalerweise über die Administrationsoberfläche
# (/administration/integrations/dji-flighthub/) gepflegt und landen dort in der Datenbank, nicht hier.
# Diese Variablen sind nur ein optionaler Deployment-Default (z. B. Docker) und ENABLED ein globaler
# Not-Aus-Schalter (auf false setzen, um die echte API org-übergreifend zu sperren, egal was in der DB steht).
DJI_FLIGHTHUB_ENABLED=true
DJI_FLIGHTHUB_BASE_URL=https://fh.dji.com
DJI_FLIGHTHUB_ORG_KEY=
DJI_FLIGHTHUB_PROJECT_UUID=

HOST_PORT=8000

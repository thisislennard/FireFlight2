FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-character-value

POSTGRES_DB=fireflight2
POSTGRES_USER=fireflight2
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql://fireflight2:change-me@fireflight2-db:5432/fireflight2

TIMEZONE=Europe/Berlin
SESSION_COOKIE_SECURE=true

FIREFLIGHT_ADMIN_USERNAME=admin
FIREFLIGHT_ADMIN_EMAIL=admin@example.org
FIREFLIGHT_ADMIN_PIN=change-me

# Web-Push (app/notifications/) -- erzeugen per `flask notifications generate-vapid-keys`.
# Ohne diese Werte funktioniert der Rest der App normal, nur Push-Versand ist deaktiviert.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@example.org

HOST_PORT=8000
